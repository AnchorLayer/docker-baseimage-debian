            {
              "id": "CVE-2025-13034-curl",
              "name": "DpkgMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2025-13034 medium vulnerability for curl package"
              },
              "fullDescription": {
                "text": "When using `CURLOPT_PINNEDPUBLICKEY` option with libcurl or `--pinnedpubkey` with the curl tool,curl should check the public key of the server certificate to verify the peer.  This check was skipped in a certain condition that would then make curl allow the connection without performing the proper check, thus not noticing a possible impostor. To skip this check, the connection had to be done with QUIC with ngtcp2 built to use GnuTLS and the user had to explicitly disable the standard certificate verification."
              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability CVE-2025-13034\nSeverity: medium\nPackage: curl\nVersion: 8.14.1-2+deb13u2\nFix Version: \nType: deb\nLocation: /var/lib/dpkg/status\nData Namespace: debian:distro:debian:13\nLink: [CVE-2025-13034](https://security-tracker.debian.org/tracker/CVE-2025-13034)",
