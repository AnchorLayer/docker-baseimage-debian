            {
              "id": "CVE-2026-40355-libgssapi-krb5-2",
              "name": "DpkgMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2026-40355 medium vulnerability for libgssapi-krb5-2 package"
              },
              "fullDescription": {
                "text": "In MIT Kerberos 5 (aka krb5) before 1.22.3, there is a NULL pointer dereference if an application calls gss_accept_sec_context() on a system with a NegoEx mechanism registered in /etc/gss/mech. An unauthenticated remote attacker can trigger this, causing the process to terminate in parse_nego_message."
              },
              "helpUri": "https://security-tracker.debian.org/tracker/CVE-2026-40355",
              "help": {
                "text": "Vulnerability CVE-2026-40355\nSeverity: medium\nPackage: libgssapi-krb5-2\nVersion: 1.22.1-2+b1\nFix Version: 1.22.1-2.1\nType: deb\nLocation: /var/lib/dpkg/status\nData Namespace: debian:distro:debian:unstable\nLink: [CVE-2026-40355](https://security-tracker.debian.org/tracker/CVE-2026-40355)",
