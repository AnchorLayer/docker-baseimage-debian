            {
              "id": "CVE-2026-34743-liblzma5",
              "name": "DpkgMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2026-34743 medium vulnerability for liblzma5 package"
              },
              "fullDescription": {
                "text": "XZ Utils provide a general-purpose data-compression library plus command-line tools. Prior to version 5.8.3, if lzma_index_decoder() was used to decode an Index that contained no Records, the resulting lzma_index was left in a state where where a subsequent lzma_index_append() would allocate too little memory, and a buffer overflow would occur. This issue has been patched in version 5.8.3."
              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability CVE-2026-34743\nSeverity: medium\nPackage: liblzma5\nVersion: 5.2.5-2.1~deb11u1\nFix Version: \nType: deb\nLocation: /var/lib/dpkg/status\nData Namespace: debian:distro:debian:11\nLink: [CVE-2026-34743](https://security-tracker.debian.org/tracker/CVE-2026-34743)",
