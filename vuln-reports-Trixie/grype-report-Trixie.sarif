            {
              "id": "CVE-2026-4046-libc-bin",
              "name": "DpkgMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2026-4046 high vulnerability for libc-bin package"
              },
              "fullDescription": {
                "text": "The iconv() function in the GNU C Library versions 2.43 and earlier may crash due to an assertion failure when converting inputs from the IBM1390 or IBM1399 character sets, which may be used to remotely crash an application.    This vulnerability can be trivially mitigated by removing the IBM1390 and IBM1399 character sets from systems that do not need them."
              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability CVE-2026-4046\nSeverity: high\nPackage: libc-bin\nVersion: 2.41-12+deb13u2\nFix Version: \nType: deb\nLocation: /var/lib/dpkg/status\nData Namespace: debian:distro:debian:13\nLink: [CVE-2026-4046](https://security-tracker.debian.org/tracker/CVE-2026-4046)",
