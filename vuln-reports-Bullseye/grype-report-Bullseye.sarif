            {
              "id": "CVE-2025-14017-libcurl4",
              "name": "DpkgMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2025-14017 low vulnerability for libcurl4 package"
              },
              "fullDescription": {
                "text": "When doing multi-threaded LDAPS transfers (LDAP over TLS) with libcurl, changing TLS options in one thread would inadvertently change them globally and therefore possibly also affect other concurrently setup transfers.  Disabling certificate verification for a specific transfer could unintentionally disable the feature for other threads as well."
              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability CVE-2025-14017\nSeverity: low\nPackage: libcurl4\nVersion: 7.74.0-1.3+deb11u16\nFix Version: \nType: deb\nLocation: /var/lib/dpkg/status\nData Namespace: debian:distro:debian:11\nLink: [CVE-2025-14017](https://security-tracker.debian.org/tracker/CVE-2025-14017)",
