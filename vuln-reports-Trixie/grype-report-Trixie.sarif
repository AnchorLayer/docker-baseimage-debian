            {
              "id": "CVE-2025-15079-curl",
              "name": "DpkgMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2025-15079 low vulnerability for curl package"
              },
              "fullDescription": {
                "text": "When doing SSH-based transfers using either SCP or SFTP, and setting the known_hosts file, libcurl could still mistakenly accept connecting to hosts *not present* in the specified file if they were added as recognized in the libssh *global* known_hosts file."
              },
