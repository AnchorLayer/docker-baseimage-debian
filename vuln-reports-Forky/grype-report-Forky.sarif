            {
              "id": "CVE-2026-27171-zlib1g",
              "name": "DpkgMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2026-27171 medium vulnerability for zlib1g package"
              },
              "fullDescription": {
                "text": "zlib before 1.3.2 allows CPU consumption via crc32_combine64 and crc32_combine_gen64 because x2nmodp can do right shifts within a loop that has no termination condition."
              },
              "helpUri": "https://security-tracker.debian.org/tracker/CVE-2026-27171",
